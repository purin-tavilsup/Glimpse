#!/usr/bin/env bash
# Fast wrapper for the Glimpse.Capture CLI.
#
# `dotnet run --project ...` rebuilds/restores on every call, which drags the
# render -> Read -> iterate loop. This runs the already-built DLL directly, which
# is much faster. It builds once if the DLL is missing; set GLIMPSE_REBUILD=1 to
# force a rebuild after changing the tool's source.
#
# Usage:  ./scripts/glimpse <source> [--renderer NAME] [--name NAME] [--out DIR] ...
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROJ="$ROOT/tools/Glimpse.Capture/Glimpse.Capture.csproj"
DLL="$ROOT/tools/Glimpse.Capture/bin/Debug/net10.0/Glimpse.Capture.dll"

if [ ! -f "$DLL" ] || [ "${GLIMPSE_REBUILD:-0}" = "1" ]; then
    echo "glimpse: building Glimpse.Capture..." >&2
    dotnet build "$PROJ" -v quiet >&2
fi

exec dotnet "$DLL" "$@"
